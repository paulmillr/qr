{
  "name": "qr",
  "version": "0.6.0",
  "description": "Minimal 0-dep QR code generator & reader. Supports ascii, term, gif and svg formats",
  "files": [
    "index.js",
    "index.js.map",
    "index.d.ts",
    "index.d.ts.map",
    "decode.js",
    "decode.js.map",
    "decode.d.ts",
    "decode.d.ts.map",
    "dom.js",
    "dom.js.map",
    "dom.d.ts",
    "dom.d.ts.map",
    "src",
    "LICENSE",
    "LICENSE-MIT"
  ],
  "devDependencies": {
    "@paulmillr/jsbt": "0.6.0",
    "@types/jsdom": "21.1.7",
    "@types/node": "25.3.0",
    "canvas": "3.2.3",
    "global-jsdom": "26.0.0",
    "jpeg-js": "0.4.4",
    "jsdom": "26.0.0",
    "omggif": "1.0.10",
    "prettier": "3.6.2",
    "typescript": "6.0.2"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "npx --no @paulmillr/jsbt bundle test/build",
    "check": "npx --no @paulmillr/jsbt check",
    "bench": "cd test/benchmark && npm ci && node index.ts",
    "format": "prettier --write src",
    "test": "node --no-warnings test/index.ts",
    "test:bun": "bun test/index.ts",
    "test:deno": "deno --allow-env --allow-read test/index.ts",
    "test:node20": "cd test; npx tsc; cd compiled/test; node index.js"
  },
  "exports": {
    ".": "./index.js",
    "./decode.js": "./decode.js",
    "./dom.js": "./dom.js"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "keywords": [
    "qr",
    "code",
    "qr code",
    "qr pattern",
    "qr generator",
    "qr reader",
    "ascii",
    "gif",
    "svg",
    "camera",
    "file"
  ],
  "homepage": "https://github.com/paulmillr/qr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulmillr/qr.git"
  },
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "sideEffects": false,
  "author": "Paul Miller (https://paulmillr.com)",
  "license": "(MIT OR Apache-2.0)"
}
